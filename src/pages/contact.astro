---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://taxguidekorea.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://taxguidekorea.com/contact/' }
  ]
};
---
<BaseLayout title="Contact" description="Contact Korea Tax Guide for Foreigners for corrections, partnership inquiries, or professional review requests." canonical="/contact/" jsonLd={jsonLd}>
  <main class="section narrow article">
    <Breadcrumbs items={[{ label: 'Contact' }]} />
    <h1>Contact</h1>
    <p>For corrections, source suggestions, partnership inquiries, or professional review requests, contact: <a href="mailto:hello@example.com">hello@example.com</a></p>
    <h2>Correction requests</h2>
    <p>If you believe a page contains an error or outdated statement, include the page URL, the sentence or section involved, and the official source that supports the correction.</p>
    <h2>Source suggestions</h2>
    <p>We prefer official and stable sources such as the National Tax Service, Hometax, Hi Korea, Government24, Korean Law Information Center, and Wetax. Please do not send personal blogs or forum posts as primary sources for tax rules.</p>
    <h2>No personal case review</h2>
    <p>Please do not send personal tax records, identification documents, visa documents, financial records, or urgent legal questions. This website does not provide personal tax, legal, immigration, or refund advice.</p>
  </main>
</BaseLayout>

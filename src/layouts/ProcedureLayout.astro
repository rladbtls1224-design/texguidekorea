---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CategoryPill from '../components/CategoryPill.astro';
import StepList from '../components/StepList.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import FaqSection from '../components/FaqSection.astro';
import OfficialSources from '../components/OfficialSources.astro';
import DisclaimerBlock from '../components/DisclaimerBlock.astro';
import { formatKoreaDate } from '../utils/date';

type Faq = { question: string; answer: string };
const { entry } = Astro.props as { entry: any };
const url = `/procedures/${entry.slug}/`;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    datePublished: entry.data.pubDate.toISOString(),
    dateModified: entry.data.updatedDate.toISOString(),
    author: { '@type': 'Organization', name: entry.data.author },
    articleSection: entry.data.category,
    keywords: entry.data.tags.join(', '),
    mainEntityOfPage: `https://taxguidekorea.com${url}`,
    publisher: { '@type': 'Organization', name: 'Korea Tax Guide for Foreigners' }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://taxguidekorea.com/' },
      { '@type': 'ListItem', position: 2, name: 'Procedures', item: 'https://taxguidekorea.com/procedures/' },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: `https://taxguidekorea.com${url}` }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: entry.data.faqs.map((faq: Faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer }
    }))
  }
];
---
<BaseLayout title={entry.data.title} description={entry.data.description} canonical={url} type="article" jsonLd={jsonLd}>
  <main class="article narrow">
    <Breadcrumbs items={[{ label: 'Procedures', href: '/procedures/' }, { label: entry.data.title }]} />
    <p class="eyebrow">Step-by-step procedure</p>
    <h1>{entry.data.title}</h1>
    <p class="meta">By {entry.data.author} | Last reviewed: {formatKoreaDate(entry.data.lastReviewed)} | Last updated: {formatKoreaDate(entry.data.updatedDate)}</p>
    <p><CategoryPill label={entry.data.category} /></p>
    <div class="summary-box"><strong>Short summary:</strong> {entry.data.description}</div>
    <section class="quick-answer">
      <h2>Before you use this procedure</h2>
      <p>{entry.data.quickAnswer}</p>
      <p><strong>Important:</strong> Menu names and screen layouts may change. Always check the latest information on the official Hometax or National Tax Service website.</p>
    </section>
    <section>
      <h2>Before you start</h2>
      <ul>{entry.data.beforeYouStart.map((item: string) => <li>{item}</li>)}</ul>
    </section>
    <section>
      <h2>What you need</h2>
      <ul>{entry.data.whatYouNeed.map((item: string) => <li>{item}</li>)}</ul>
    </section>
    <section>
      <h2>Steps</h2>
      <StepList steps={entry.data.steps} />
    </section>
    <section>
      <h2>What to check before submitting</h2>
      <slot />
    </section>
    <section>
      <h2>Common mistakes</h2>
      <ul>{entry.data.mistakes.map((item: string) => <li>{item}</li>)}</ul>
    </section>
    <section>
      <h2>What to do if you are stuck</h2>
      <ul>{entry.data.stuck.map((item: string) => <li>{item}</li>)}</ul>
    </section>
    <FaqSection faqs={entry.data.faqs} />
    <RelatedGuides links={entry.data.related} />
    <OfficialSources sources={entry.data.sources} />
    <DisclaimerBlock />
  </main>
</BaseLayout>

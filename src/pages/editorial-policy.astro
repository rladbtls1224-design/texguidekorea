---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://taxguidekorea.com/' },
    { '@type': 'ListItem', position: 2, name: 'Editorial Policy', item: 'https://taxguidekorea.com/editorial-policy/' }
  ]
};
---
<BaseLayout title="Editorial Policy" description="How Korea Tax Guide for Foreigners writes, reviews, updates, and corrects general educational tax content for foreigners in Korea." canonical="/editorial-policy/" jsonLd={jsonLd}>
  <main class="section narrow article">
    <Breadcrumbs items={[{ label: 'Editorial Policy' }]} />
    <h1>Editorial Policy</h1>
    <p>Korea Tax Guide for Foreigners publishes general educational content for foreigners living, working, studying, or freelancing in Korea. Our goal is to explain common Korean tax terms, Hometax procedures, tax document workflows, and related administrative concepts in clear English.</p>
    <h2>How content is prepared</h2>
    <p>We write for practical understanding, not for personal tax planning. Where possible, articles point readers to official sources such as the National Tax Service, Hometax, Hi Korea, Government24, the Korean Law Information Center, or Wetax. When an exact official deep link is uncertain or may change, we prefer stable official homepage links.</p>
    <h2>Review and updates</h2>
    <p>Tax rules, administrative screens, immigration document requirements, and certificate procedures may change. Articles include last reviewed and last updated dates where applicable. Content may be revised when official information changes, errors are found, or readers request corrections.</p>
    <h2>What we do not provide</h2>
    <p>This website does not provide personalized tax, legal, immigration, accounting, refund, or filing advice. We do not guarantee refunds, tax savings, filing outcomes, visa outcomes, or document acceptance by any institution.</p>
    <h2>Corrections</h2>
    <p>If you find a possible error, outdated statement, broken link, or unclear explanation, please use the <a href="/contact/">contact page</a>. Include the page URL, the sentence or section involved, and any official source that supports the correction.</p>
  </main>
</BaseLayout>
